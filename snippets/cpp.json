			"",
			"class DisjointSet",
			"{",
			"\tpublic:",
			"\t\tvector<int> rank, parent, size;",
			"\t\tint components;",
			"",
			"\t\tenum Indexing { ZERO_INDEXED = 0, ONE_INDEXED = 1 };",
			"",
			"\t\tDisjointSet(int n, Indexing mode = ONE_INDEXED)",
			"\t\t{",
			"\t\t\trank.resize(n + mode, 0);",
			"\t\t\tparent.resize(n + mode);",
			"\t\t\tsize.resize(n + mode, 1);",
			"\t\t\tcomponents = n;",
			"",
			"\t\t\tfor (int i = 0; i < n + mode; i++) {",
			"\t\t\t\tparent[i] = i;",
			"\t\t\t}",
			"\t\t}",
			"",
			"\t\tint find_root(int node)",
			"\t\t{",
			"\t\t\tif (node == parent[node]) {",
			"\t\t\t\treturn node;",
			"\t\t\t}",
			"\t\t\tparent[node] = find_root(parent[node]);",
			"\t\t\treturn parent[node];",
			"\t\t}",
			"",
			"\t\t// true if merged, false if already in same set",
			"\t\tbool union_by_size(int u, int v)",
			"\t\t{",
			"\t\t\tint root_u = find_root(u);",
			"\t\t\tint root_v = find_root(v);",
			"",
			"\t\t\tif (root_u == root_v) {",
			"\t\t\t\treturn false;",
			"\t\t\t}",
			"",
			"\t\t\tif (size[root_u] < size[root_v]) {",
			"\t\t\t\tparent[root_u] = root_v;",
			"\t\t\t\tsize[root_v] += size[root_u];",
			"\t\t\t} else {",
			"\t\t\t\tparent[root_v] = root_u;",
			"\t\t\t\tsize[root_u] += size[root_v];",
			"\t\t\t}",
			"",
			"\t\t\tcomponents--;",
			"\t\t\treturn true;",
			"\t\t}",
			"",
			"\t\tbool is_connected(int u, int v) { return find_root(u) == find_root(v); }",
			"};",
			"",
			"bool is_square(int x)",
			"{",
			"\tint res = sqrt(x);",
			"\twhile (res * res > x)",
			"\t\tres--;",
			"\twhile ((res + 1) * (res + 1) <= x)",
			"\t\tres++;",
			"\treturn res * res == x;",
			"}",
			"",
			"int binary_search(int key, const vector<int> &arr)",
			"{",
			"\tint left = 0, right = arr.size() - 1;",
			"\twhile (left <= right) {",
			"\t\tint mid = left + (right - left) / 2;",
			"\t\tif (arr[mid] == key)",
			"\t\t\treturn mid;",
			"\t\telse if (arr[mid] < key)",
			"\t\t\tleft = mid + 1;",
			"\t\telse",
			"\t\t\tright = mid - 1;",
			"\t}",
			"\treturn -1;",
			"}",
			"",
			"bool is_prime(int n)",
			"{",
			"\tif (n <= 1) {",
			"\t\treturn false;",
			"\t}",
			"\tif (n <= 3) {",
			"\t\treturn true;",
			"\t}",
			"",
			"\tif (n % 2 == 0 || n % 3 == 0) {",
			"\t\treturn false;",
			"\t}",
			"",
			"\tfor (int i = 5; i * i <= n; i += 6) {",
			"\t\tif (n % i == 0 || n % (i + 2) == 0) {",
			"\t\t\treturn false;",
			"\t\t}",
			"\t}",
			"\treturn true;",
			"}",
			"",
			"void solve()",
			"{",
			"\t$0",
			"}",
			"",
			"signed main()",
			"{",
			"\tios_base::sync_with_stdio(false);",
			"\tcin.tie(nullptr);",
			"",
			"\tint tc;",
			"\tcin >> tc;",
			"",
			"\twhile (tc--) {",
			"\t\tsolve();",
			"\t}",
			"",
			"\treturn 0;",
			"}"
		],
